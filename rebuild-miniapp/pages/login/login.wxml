<view class="page">
  <view class="card">
    <view class="section-title">账号登录</view>
    <view class="form-label">手机号</view>
    <input class="input" type="number" placeholder="请输入手机号" bindinput="onMobileChange" value="{{mobile}}" />
    <view class="form-label" style="margin-top: 24rpx;">密码</view>
    <input class="input" password placeholder="请输入密码" bindinput="onPasswordChange" value="{{password}}" />
    <button class="button-primary" style="margin-top: 32rpx;" bindtap="submit">登录</button>
  </view>
</view>
