.search-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 24rpx;
}

.search-box {
  flex: 1;
  display: flex;
  align-items: center;
  height: 88rpx;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 22rpx;
  padding: 0 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(31, 41, 55, 0.05);
}

.search-icon {
  font-size: 34rpx;
  color: #9ca3af;
  margin-right: 14rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
}

.filter-btn {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.95);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(31, 41, 55, 0.05);
  font-size: 34rpx;
  color: #6b7280;
}

.phase-text {
  color: #ef4444;
  font-size: 28rpx;
  margin-bottom: 10rpx;
}

.uuid-line {
  margin-top: 10rpx;
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.uuid-label {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 74rpx;
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #5b6b8a;
  font-size: 20rpx;
  line-height: 34rpx;
}

.uuid-text {
  min-width: 0;
  flex: 1;
  color: #8b95a7;
  font-size: 24rpx;
  line-height: 1.45;
  word-break: break-all;
}

.filter-mask {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.28);
  z-index: 20;
}

.filter-panel {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  top: 160rpx;
  background: #fff;
  border-radius: 28rpx;
  padding: 32rpx;
  z-index: 21;
  box-shadow: 0 24rpx 60rpx rgba(15, 23, 42, 0.18);
}

.filter-title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.tag-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
  margin-bottom: 30rpx;
}

.tag {
  height: 72rpx;
  border-radius: 18rpx;
  background: #f3f4f6;
  color: #4b5563;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.tag-active {
  background: rgba(46, 91, 255, 0.12);
  color: #2e5bff;
  border: 1rpx solid rgba(46, 91, 255, 0.35);
}

.filter-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 20rpx;
}

.ghost-btn {
  background: #f3f4f6;
  color: #374151;
  border-radius: 18rpx;
}
