<view class="page">
  <view class="card" wx:for="{{rows}}" wx:key="number">
    <view class="list-item">
      <view style="font-weight:600;">工单 #{{item.number}}</view>
      <view>{{item.targetTask}}</view>
      <view class="muted">{{item.remark || item.state}}</view>
    </view>
  </view>
</view>
