.hero {
  background: linear-gradient(135deg, #1f2b6b, #355dff 55%, #74a7ff);
  color: #fff;
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 10rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  opacity: 0.88;
}

.banner-card {
  margin-bottom: 24rpx;
  padding: 28rpx 32rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ff8d1e, #ffb33f);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  box-shadow: 0 18rpx 36rpx rgba(255, 161, 50, 0.24);
}

.banner-title {
  font-size: 38rpx;
  font-weight: 700;
}

.banner-subtitle {
  margin-top: 8rpx;
  font-size: 22rpx;
  opacity: 0.92;
}

.banner-action {
  flex-shrink: 0;
  padding: 18rpx 28rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  color: #e07b16;
  font-size: 26rpx;
  font-weight: 600;
}

.income-panel {
  background: linear-gradient(135deg, #355dff, #476cff 55%, #2746c9);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.income-col {
  flex: 1;
}

.income-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.income-value {
  font-size: 44rpx;
  font-weight: 700;
  margin-top: 10rpx;
}

.income-btn {
  background: #fff;
  color: #355dff;
  border-radius: 18rpx;
  padding: 22rpx 24rpx;
  font-weight: 600;
}

.notice-card {
  margin-bottom: 24rpx;
}

.notice-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.notice-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #f59e0b;
  flex-shrink: 0;
}

.stats-grid,
.shortcut-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.stats-grid-three {
  grid-template-columns: repeat(3, 1fr);
}

.stat {
  min-height: 160rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.stat-clickable {
  position: relative;
}

.stat-clickable::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 28rpx;
  border: 2rpx solid rgba(53, 93, 255, 0.12);
  pointer-events: none;
}

.stat-value {
  font-size: 42rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.shortcut {
  min-height: 100rpx;
  display: flex;
  align-items: center;
  font-weight: 600;
}

.green {
  color: #22c55e;
}

.red {
  color: #ef4444;
}

.orange {
  color: #f59e0b;
}
