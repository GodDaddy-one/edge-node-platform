.detail-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #13163c 0, #13163c 180rpx, #f6f8fb 181rpx, #f6f8fb 100%);
  padding: 24rpx;
}

.hero-bg {
  height: 40rpx;
}

.detail-card {
  background: #fff;
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 14rpx 40rpx rgba(15, 23, 42, 0.08);
  margin-bottom: 24rpx;
}

.top-card {
  margin-top: 20rpx;
}

.uuid-row,
.remark-row,
.section-row,
.table-head,
.disk-head,
.disk-row,
.summary-grid {
  display: flex;
}

.top-line {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.id-block {
  flex: 1;
  min-width: 0;
}

.id-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  flex-wrap: wrap;
}

.id-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 36rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #5b6b8a;
  font-size: 20rpx;
}

.id-text {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  color: #4b5563;
  word-break: break-all;
  line-height: 1.5;
}

.copy-link {
  color: #355dff;
  font-size: 30rpx;
  flex-shrink: 0;
  padding-top: 4rpx;
}

.node-name {
  color: #9ca3af;
  margin-top: 10rpx;
  font-size: 26rpx;
  word-break: break-all;
}

.income-title {
  margin-top: 26rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #6b7280;
}

.income-value {
  margin-top: 12rpx;
  font-size: 60rpx;
  font-weight: 700;
}

.summary-grid {
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #eef2f7;
}

.summary-col {
  flex: 1;
  min-width: 0;
}

.summary-label {
  color: #6b7280;
  font-size: 28rpx;
}

.summary-value {
  margin-top: 8rpx;
  font-size: 36rpx;
  word-break: break-word;
}

.mini-btn {
  margin-top: 10rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 90rpx;
  height: 52rpx;
  background: #355dff;
  color: #fff;
  border-radius: 14rpx;
  font-size: 28rpx;
}

.remark-row {
  justify-content: space-between;
  margin-top: 28rpx;
}

.remark-input {
  margin-top: 16rpx;
  height: 84rpx;
  border-radius: 18rpx;
  background: #f3f5f9;
  padding: 0 20rpx;
  font-size: 30rpx;
}

.tab-bar {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border: 1rpx solid #355dff;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff;
  margin-bottom: 24rpx;
}

.tab-item {
  height: 78rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #355dff;
  background: #fff;
  font-size: 30rpx;
}

.tab-item-active {
  background: #355dff;
  color: #fff;
}

.section-title {
  font-size: 40rpx;
  font-weight: 700;
  margin: 24rpx 0 16rpx;
}

.section-row {
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #eef2f7;
  font-size: 32rpx;
}

.section-row:last-child {
  border-bottom: none;
}

.action-value {
  color: #355dff;
  font-weight: 600;
}

.table-card {
  border: 1rpx solid #eef2f7;
  border-radius: 16rpx;
  overflow: hidden;
  margin-top: 12rpx;
}

.table-head,
.disk-head {
  background: #eef2ff;
  font-size: 28rpx;
  color: #4b5563;
}

.table-head view,
.disk-head view,
.disk-row view {
  flex: 1;
  padding: 18rpx 12rpx;
  text-align: center;
}

.table-empty {
  text-align: center;
  padding: 30rpx 0;
  color: #9ca3af;
}

.disk-table {
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #eef2f7;
  margin-top: 12rpx;
}

.disk-row {
  border-top: 1rpx solid #eef2f7;
  font-size: 28rpx;
}
