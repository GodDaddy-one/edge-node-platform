.date-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.date-card {
  flex: 1;
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 41, 55, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.date-label {
  font-size: 28rpx;
  color: #6b7280;
}

.date-value {
  color: #355dff;
  font-size: 30rpx;
  font-weight: 600;
}

.monitor-card {
  padding-bottom: 28rpx;
}

.uuid-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 28rpx;
}

.uuid-label {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 82rpx;
  height: 36rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  background: #eef2ff;
  color: #5b6b8a;
  font-size: 20rpx;
}

.uuid-text {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  word-break: break-all;
  line-height: 1.5;
}

.tab-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.tab-group,
.range-group {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex-wrap: wrap;
}

.period-tab {
  font-size: 42rpx;
  color: #666;
  position: relative;
  padding-bottom: 8rpx;
}

.period-tab-active {
  color: #355dff;
  font-weight: 600;
}

.period-tab-active::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 6rpx;
  border-radius: 999rpx;
  background: #355dff;
}

.range-group {
  border: 1rpx solid #355dff;
  border-radius: 16rpx;
  overflow: hidden;
  gap: 0;
}

.range-tab {
  min-width: 92rpx;
  text-align: center;
  padding: 16rpx 0;
  color: #355dff;
  font-size: 24rpx;
  background: #ffffff;
}

.range-tab-active {
  background: #355dff;
  color: #ffffff;
  font-weight: 600;
}

.chart-empty {
  padding: 54rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbfdff, #f4f8ff);
  border: 1rpx solid #edf2ff;
  margin-bottom: 36rpx;
  text-align: center;
}

.chart-empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #6b7280;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 36rpx;
}

.info-item,
.metric-card {
  background: #f8fbff;
  border-radius: 20rpx;
  padding: 24rpx;
}

.info-label,
.metric-label {
  color: #6b7280;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.info-value,
.metric-value {
  font-size: 32rpx;
  font-weight: 600;
  word-break: break-all;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}
