<view class="page">
  <view class="card" wx:if="{{loading}}">
    <view class="muted">正在加载收益明细...</view>
  </view>

  <view class="card" wx:if="{{!loading && note}}">
    <view class="muted">账号备注</view>
    <view style="font-size: 30rpx; font-weight: 600; margin-top: 12rpx;">{{note}}</view>
  </view>

  <view class="card" wx:if="{{!loading && !rows.length}}">
    <view class="muted">暂时还没有可展示的收益数据</view>
  </view>

  <view class="card" wx:for="{{rows}}" wx:key="date" wx:if="{{!loading}}">
    <view class="list-item">
      <view>{{item.date}}</view>
      <view style="font-size: 36rpx; font-weight: 700;">¥ {{item.amount}}</view>
      <view class="muted">{{item.remark}}</view>
    </view>
  </view>
</view>
